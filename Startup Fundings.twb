      <aliases enabled='yes' />
      <column caption='Funding ( USD)' datatype='integer' datatype-customized='true' default-format='c&quot;$&quot;#,##0,,.00M' name='[Amount in USD]' role='measure' type='quantitative' />
      <column datatype='real' default-format='p0.00%' name='[Calculation1]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Amount in USD]) / TOTAL(SUM([Amount in USD]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Average Funding Per Startupp' datatype='real' default-format='c&quot;$&quot;#,##0' name='[Calculation_1474457519267840]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Amount in USD])/COUNTD([Startup Name])' />
      </column>
      <column caption='Total Investors' datatype='integer' name='[Calculation_1474457530273793]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([Investors Name])' />
      </column>
      <column caption='Top 10 investers' datatype='string' name='[Calculation_1474457577390082]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='LEFT([Investors Name],20)' />
      </column>
      <column caption='Total Startups' datatype='integer' default-format='c#,##0' name='[Calculation_1646255912165376]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([Startup Name])' />
      </column>
      <column caption='Top Invester' datatype='integer' name='[Calculation_1646255921258498]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([Investors Name])' />
      </column>
      <column caption='Top Invester Name' datatype='string' name='[Calculation_1646255938383875]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='SPLIT([Investors Name],&quot;,&quot;,1)' />
      </column>
      <column caption='month Date' datatype='integer' name='[Calculation_1702055830544384]' role='measure' type='quantitative'>
