            <column caption='Funding ( USD)' datatype='integer' datatype-customized='true' default-format='c&quot;$&quot;#,##0,,.00M' name='[Amount in USD]' role='measure' type='quantitative' />
            <column datatype='string' name='[City  Location (group)]' role='dimension' semantic-role='[City].[Name]' type='nominal'>
              <calculation class='categorical-bin' column='[City  Location]' new-bin='true'>
